# Variables de entorno necesarias para las funciones serverless (api/*.js).
# En producción (Vercel) estas se crean automáticamente si conectas la
# integración "Upstash Redis" desde el Marketplace de Vercel (Storage > Create Database).
#
# Para desarrollo local: copia este archivo a ".env", crea una base de datos
# gratuita en https://console.upstash.com y pega aquí sus credenciales,
# o ejecuta `vercel env pull .env.development.local` si ya está conectada en Vercel.

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternativa: nombres nativos de Upstash (también soportados por api/_utils.js)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Token secreto para acceder al panel de moderación (admin.html) y al endpoint
# /api/moderar. Genera un valor largo y aleatorio, por ejemplo con:
#   openssl rand -hex 32
# Sin esta variable configurada, el panel de moderación queda deshabilitado
# por completo (el endpoint responde 401 siempre).
ADMIN_TOKEN=
